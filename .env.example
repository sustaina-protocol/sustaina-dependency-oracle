# Sustaina Dependency Oracle - Example Environment Configuration
# Copy this file to .env for local development

# =============================================================================
# ORACLE SERVICE
# =============================================================================

# Port the Oracle service listens on
ORACLE_PORT=3000

# Node environment
NODE_ENV=development

# Log level (debug, info, warn, error)
LOG_LEVEL=debug

# Ed25519 secret key (base64-encoded, 32 bytes)
# Generate with: openssl genpkey -algorithm ed25519 -outform DER | base64
ORACLE_SECRET_KEY=

# =============================================================================
# STELLAR / SOROBAN CONFIGURATION
# =============================================================================

# Network selection (testnet or public)
STELLAR_NETWORK=testnet

# Soroban RPC endpoint
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# Network passphrase
SOROBAN_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# Smart contract ID for identity registry
# Get after deployment
REGISTRY_CONTRACT_ID=

# =============================================================================
# CLI TOOL
# =============================================================================

# Registry RPC URL for CLI tool
CLI_REGISTRY_RPC=https://soroban-testnet.stellar.org

# Default split percentage (1-100)
CLI_DEFAULT_SPLIT=10

# =============================================================================
# FRONTEND
# =============================================================================

# Oracle URL for frontend
NEXT_PUBLIC_ORACLE_URL=http://localhost:3000

# Registry contract ID for frontend
NEXT_PUBLIC_REGISTRY_CONTRACT=

# Soroban RPC for frontend
NEXT_PUBLIC_SOROBAN_RPC=https://soroban-testnet.stellar.org

# =============================================================================
# MONITORING (Optional)
# =============================================================================

# Datadog API Key (optional)
# DD_API_KEY=

# Datadog environment tag
# DD_ENV=development

# Datadog service name
# DD_SERVICE=sustaina-oracle

# =============================================================================
# DEVELOPMENT ONLY
# =============================================================================

# Enable verbose output
VERBOSE=false

# Skip signature verification (development only!)
# SKIP_SIGNATURE_VERIFICATION=false

# Mock GitHub OIDC verification (development only!)
# MOCK_GITHUB_OIDC=false

# =============================================================================
# NOTES
# =============================================================================

# To generate Ed25519 private key:
#   openssl genpkey -algorithm ed25519 -outform DER | base64
#
# To generate from that key:
#   openssl genpkey -algorithm ed25519 -outform DER | base64 -w 0 | \
#     openssl pkey -inform DER -outform DER -pubout 2>/dev/null | base64
#
# For local development, generate a test key:
#   make test-keys  # (if added to Makefile)
