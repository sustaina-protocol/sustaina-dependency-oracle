# Oracle Service Configuration

# Port the Oracle service listens on
PORT=3000

# Ed25519 secret key in base64 format
# Generate with: openssl genpkey -algorithm ed25519 -outform DER | base64
ORACLE_SECRET_KEY=

# Optional: Stellar RPC endpoint (for future enhancements)
STELLAR_RPC_URL=https://soroban-testnet.stellar.org

# Optional: Soroban Network Passphrase
SOROBAN_NETWORK_PASSPHRASE=Test SDF Network ; September 2015
